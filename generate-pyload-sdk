#!/bin/sh

# spec_file='http://localhost:8000/api/openapi.json'
# spec_file='openapi.json'

# Set default values
spec_file='https://raw.githubusercontent.com/pyload/pyload/refs/heads/develop/openapi-generator/openapi.json'
output_directory='./.pyload-sdk'

# Parse command-line arguments
while getopts 's:o:h' opt; do
  case $opt in
    s) spec_file=$OPTARG ;;
    o) output_directory=$OPTARG ;;
    h) printf 'Usage: %s [-s spec] [-o output]\n' "$0"; exit 0 ;;
    *) printf 'Usage: %s [-s spec] [-o output]\n' "$0"; exit 1 ;;
  esac
done

# Check if openapi-generator-cli is installed
if ! command -v openapi-generator-cli >/dev/null 2>&1; then
  printf '\nError: openapi-generator-cli is missing\n'
  printf '\nInstall it with:\n'
  printf '  npm install -g @openapitools/openapi-generator-cli\n'
  printf '\nSee: https://github.com/OpenAPITools/openapi-generator-cli#installation\n'
  exit 1
fi

# Generate Rust SDK from OpenAPI spec
openapi-generator-cli generate \
  -i "$spec_file" \
  -g rust \
  -o "$output_directory"

# Fix the generator bug that produces `models::models::` instead of `models::`
sed -i 's/models::models::/models::/g' "$output_directory/src/apis/py_load_rest_api.rs"

# Add SDK as dependency to main project
cargo add --path "$output_directory" openapi

# Add generated SDK to local git ignore
if ! grep -qx "$output_directory" '.git/info/exclude'; then
  mkdir -p '.git/info/'
  printf "$output_directory\n" >> '.git/info/exclude'
fi
